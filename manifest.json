{
  "manifest_version": 3,
  "name": "ОТКЛИК24",
  "version": "1.1.1",
  "description": "Автоматизируй отклики на HH.ru за секунды. Лимиты, шаблоны и умный анти-бот.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.hh.ru/*", "*://hh.ru/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
